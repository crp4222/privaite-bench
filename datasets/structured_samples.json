  {
    "id": "tool_send_email",
    "lang": "en",
    "source": "Self-built — realistic function-calling payload",
    "messages": [
      {
        "role": "assistant",
        "content": null,
        "tool_calls": [
          {
            "id": "call_1",
            "type": "function",
            "function": {
              "name": "send_email",
              "arguments": "{\"to\": \"Sarah Johnson <sarah.j@company.org>\", \"body\": \"Please call me back at +1 212 555 0199.\"}"
            }
          }
        ]
      }
    ],
    "expected": {
      "Sarah Johnson": "PERSON",
      "sarah.j@company.org": "EMAIL_ADDRESS",
      "+1 212 555 0199": "PHONE_NUMBER"
    }
  },
